PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# ─── Email / Nodemailer ─────────────────────────────────────────────────────
# Supports any SMTP provider (Brevo, Gmail, etc.)
#
# For Gmail (alternative):
#   MAIL_HOST = smtp.gmail.com  |  MAIL_PORT = 587
#   MAIL_USER = your@gmail.com  |  MAIL_PASS = 16-char App Password
#   MAIL_FROM = your@gmail.com  |  MAIL_TO   = your@gmail.com
# ────────────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your_brevo_smtp_login
MAIL_PASS=your_brevo_smtp_key
MAIL_FROM=your_verified_sender@example.com
MAIL_TO=your@email.com

# ─── Cloudinary (Image Uploads) ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Groq AI
GROQ_API_KEY=your_groq_api_key_here
